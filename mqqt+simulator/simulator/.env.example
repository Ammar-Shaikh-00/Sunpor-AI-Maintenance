# Local Mosquitto (mqqtBroker/docker-compose.yml)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Must match subscriber TOPIC subscription (EX10/#)
TOPIC=EX10/live

# How often to publish a COV batch
PUBLISH_INTERVAL_SECONDS=2

# How many catalog signals change per tick (COV simulation)
COV_SIGNALS_PER_TICK=5

QUALITY=GOOD

# Set true to test subscriber tag normalization (SUN_POLY2_SRV prefix)
USE_POLY2_PREFIX=false
